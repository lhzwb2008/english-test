# 从 Coze 开放平台获取：https://www.coze.cn/open/oauth/pats
# 或你提供的 Service / PAT（勿提交真实值到 Git）
COZE_API_TOKEN=

# 国内站默认；国际站可改为 https://api.coze.com
COZE_BASE_URL=https://api.coze.cn

# 调试对话时使用的终端用户标识（可任意固定字符串）
COZE_DEBUG_USER_ID=local-dev-user

# 可选：创建智能体时指定空间（默认脚本内「共享空间」）
# COZE_SPACE_ID=

# 可选：创建时指定模型 ID（不设置则使用空间默认模型）
# COZE_MODEL_ID=
